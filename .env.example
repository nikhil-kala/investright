# Laravel API (local: npm run api, or XAMPP: http://localhost/investright-api/public/api)
VITE_API_URL=http://127.0.0.1:8000/api
VITE_USE_LARAVEL_API=true

# Legacy Supabase (fallback when VITE_USE_LARAVEL_API=false)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI / ChatGPT (used by the financial chatbot)
VITE_OPENAI_API_KEY=your_openai_api_key
VITE_OPENAI_MODEL=gpt-4o-mini

# Application Configuration
VITE_APP_NAME=InvestRight
VITE_APP_VERSION=4.0.0
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
